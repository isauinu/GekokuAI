# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you may want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#1197, it is "better not to commit Pipfile.lock to version control".
#   But it is recommended to commit Pipfile.lock when deploying an application.
#Pipfile.lock

# poetry
#   Poetry uses poetry.lock to ensure reproducible builds.
#   For libraries, ignore it. For applications, commit it.
#poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-plugins/

